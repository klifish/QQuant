# Environment configuration for QQuant
# Copy this file to config/secrets.env and fill in your API keys

# Tushare API Token (for A-share market data)
# Get your token from https://tushare.pro/
TUSHARE_TOKEN=your_tushare_token_here

# OpenAI API Key (for AI strategy generation)
# Get your key from https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Other data provider configurations
# ALPACA_API_KEY=your_alpaca_key_here
# ALPACA_SECRET_KEY=your_alpaca_secret_here

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO